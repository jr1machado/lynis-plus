#################################################################################
#
# CIS Benchmark mapping - Ubuntu 22.04 LTS - LEVEL 1
# Source: CIS_Ubuntu_Linux_22.04_LTS_Benchmark_v3.0.0.pdf (Level 1 only)
#
# Same format as ubuntu2404.rules - see that file for field documentation.
# Section numbers verified against this benchmark's real table of contents
# (v3.0.0 template) - mostly identical to the 24.04/v2.0.0 file but a few
# kernel sysctl and logrotate controls are numbered/classified differently,
# do not assume section numbers are interchangeable between the two files.
#
#################################################################################

[SSH-001]
test-no=SSH-7408
title=Ensure sshd PermitRootLogin is disabled
section=5.1.20
severity=High
category=security
level=L1
mapping=exact
backup-file=/etc/ssh/sshd_config
fix-cmd=grep -Eq '^[[:space:]]*PermitRootLogin' /etc/ssh/sshd_config && sed -i -E 's/^[[:space:]]*#?[[:space:]]*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config || echo 'PermitRootLogin no' >> /etc/ssh/sshd_config
verify-cmd=grep -Eq '^PermitRootLogin[[:space:]]+no' /etc/ssh/sshd_config
post-cmd=sshd -t 2>/dev/null && (systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null) || true

[SSH-002]
test-no=SSH-7440
title=Ensure sshd access is configured
section=5.1.4
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-001]
test-no=AUTH-9204
title=Ensure root is the only UID 0 account
section=5.4.2.1
severity=High
category=security
level=L1
mapping=exact

[AUTH-002]
test-no=AUTH-9208
title=Ensure no duplicate user names exist
section=7.2.7
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-003]
test-no=AUTH-9222
title=Ensure no duplicate GIDs exist
section=7.2.6
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-004]
test-no=AUTH-9226
title=Ensure no duplicate group names exist
section=7.2.8
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-005]
test-no=AUTH-9328
title=Ensure default user umask is configured
section=5.4.3.3
severity=Low
category=security
level=L1
mapping=exact
backup-file=/etc/profile
fix-cmd=grep -Eq '^[[:space:]]*umask[[:space:]]+[0-9]+' /etc/profile && sed -i -E 's/^([[:space:]]*umask[[:space:]]+)[0-9]+/\1027/' /etc/profile || echo 'umask 027' >> /etc/profile
verify-cmd=grep -Eq '^[[:space:]]*umask[[:space:]]+(077|027|0077|0027)([^0-9]|$)' /etc/profile

[AUTH-006]
test-no=AUTH-9262
title=Ensure pam_pwquality module is enabled
section=5.3.2.3
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis checks presence of password strength testing tools in general (PAM), CIS control specifically requires the pam_pwquality module
fix-cmd=apt-get install -y libpam-pwquality >/dev/null 2>&1
verify-cmd=ls /usr/lib/*/security/pam_pwquality.so /lib/security/pam_pwquality.so /lib64/security/pam_pwquality.so /usr/lib/security/pam_pwquality.so 2>/dev/null | grep -q pam_pwquality

[AUTH-007]
test-no=AUTH-9286
title=Ensure password expiration is configured
section=5.4.1.1
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis checks general user password aging, CIS control specifies the exact PASS_MAX_DAYS threshold
backup-file=/etc/login.defs
fix-cmd=(grep -Eq '^PASS_MIN_DAYS' /etc/login.defs && sed -i -E 's/^PASS_MIN_DAYS[[:space:]]+[0-9]+/PASS_MIN_DAYS   1/' /etc/login.defs || echo 'PASS_MIN_DAYS   1' >> /etc/login.defs); (grep -Eq '^PASS_MAX_DAYS' /etc/login.defs && sed -i -E 's/^PASS_MAX_DAYS[[:space:]]+[0-9]+/PASS_MAX_DAYS   365/' /etc/login.defs || echo 'PASS_MAX_DAYS   365' >> /etc/login.defs)
verify-cmd=MIN=$(grep -E '^PASS_MIN_DAYS' /etc/login.defs | awk '{print $2}'); MAX=$(grep -E '^PASS_MAX_DAYS' /etc/login.defs | awk '{print $2}'); [ -n "$MIN" ] && [ "$MIN" != "0" ] && [ -n "$MAX" ] && [ "$MAX" != "99999" ]

[KRNL-001]
test-no=KRNL-5820
title=Ensure suid_dumpable is configured
section=1.5.3
severity=Medium
category=security
level=L1
mapping=exact
backup-file=/etc/systemd/coredump.conf
fix-cmd=grep -q '^\[Coredump\]' /etc/systemd/coredump.conf 2>/dev/null || printf '\n[Coredump]\n' >> /etc/systemd/coredump.conf; (grep -q '^ProcessSizeMax=' /etc/systemd/coredump.conf && sed -i 's/^ProcessSizeMax=.*/ProcessSizeMax=0/' /etc/systemd/coredump.conf || sed -i '/^\[Coredump\]/a ProcessSizeMax=0' /etc/systemd/coredump.conf); (grep -q '^Storage=' /etc/systemd/coredump.conf && sed -i 's/^Storage=.*/Storage=none/' /etc/systemd/coredump.conf || sed -i '/^\[Coredump\]/a Storage=none' /etc/systemd/coredump.conf)
verify-cmd=grep -Eq '^ProcessSizeMax=0[[:space:]]*$' /etc/systemd/coredump.conf && grep -Eq '^Storage=none[[:space:]]*$' /etc/systemd/coredump.conf

[KRNL-002]
test-no=KRNL-6000
title=Ensure randomize_va_space is configured
section=1.5.1
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis test is a generic sysctl key/value checker driven by the scan profile, not a dedicated randomize_va_space test
fix-cmd=mkdir -p /etc/sysctl.d && printf '%s\n' 'kernel.dmesg_restrict = 1' > /etc/sysctl.d/60-cis-krnl002.conf && sysctl -w kernel.dmesg_restrict=1 >/dev/null 2>&1
verify-cmd=[ "$(sysctl -n kernel.dmesg_restrict 2>/dev/null)" = "1" ]

[KRNL-003]
test-no=KRNL-6000
title=Ensure ptrace_scope is configured
section=1.5.2
severity=Low
category=security
level=L1
mapping=approx
note=Same generic sysctl checker as KRNL-002, applied to a different sysctl key
fix-cmd=mkdir -p /etc/sysctl.d && printf '%s\n' 'kernel.kptr_restrict = 2' > /etc/sysctl.d/60-cis-krnl003.conf && sysctl -w kernel.kptr_restrict=2 >/dev/null 2>&1
verify-cmd=[ "$(sysctl -n kernel.kptr_restrict 2>/dev/null)" = "2" ]

[MACF-001]
test-no=MACF-6204
title=Ensure the apparmor packages are installed
section=1.3.1.1
severity=Medium
category=security
level=L1
mapping=exact
fix-cmd=apt-get install -y apparmor apparmor-utils >/dev/null 2>&1
verify-cmd=command -v aa-status >/dev/null 2>&1

[MACF-002]
test-no=MACF-6208
title=Ensure AppArmor is enabled
section=1.3.1.2
severity=High
category=security
level=L1
mapping=exact
fix-cmd=systemctl enable --now apparmor >/dev/null 2>&1
verify-cmd=aa-status >/dev/null 2>&1

[BANN-001]
test-no=BANN-7124
title=Ensure /etc/issue is configured
section=1.6.2
severity=Low
category=security
level=L1
mapping=exact
backup-file=/etc/issue
fix-cmd=test -s /etc/issue || printf 'Authorized users only. All activity may be monitored and reported.\nUnauthorized access to this system is prohibited and may be subject to civil and criminal penalties.\nBy using this system, you consent to such monitoring and information collection in accordance with applicable law.\nDisconnect immediately if you do not agree with these terms.\n' > /etc/issue
verify-cmd=test -s /etc/issue

[BANN-002]
test-no=BANN-7128
title=Ensure /etc/issue.net is configured
section=1.6.3
severity=Low
category=security
level=L1
mapping=exact
backup-file=/etc/issue.net
fix-cmd=test -s /etc/issue.net || printf 'Authorized users only. All activity may be monitored and reported.\nUnauthorized access to this system is prohibited and may be subject to civil and criminal penalties.\nBy using this system, you consent to such monitoring and information collection in accordance with applicable law.\nDisconnect immediately if you do not agree with these terms.\n' > /etc/issue.net
verify-cmd=test -s /etc/issue.net

[SCHD-001]
test-no=SCHD-7702
title=Ensure cron daemon is enabled and active
section=2.4.1.1
severity=Low
category=security
level=L1
mapping=exact
fix-cmd=apt-get install -y cron >/dev/null 2>&1; systemctl enable --now cron >/dev/null 2>&1
verify-cmd=pgrep -x cron >/dev/null 2>&1

[SCHD-002]
test-no=SCHD-7718
title=Ensure access to at is configured
section=2.4.2.1
severity=Low
category=security
level=L1
mapping=approx
note=Lynis checks presence/listing of at users, CIS control specifically checks file permissions on the at.allow/at.deny access files
fix-cmd=touch /etc/at.allow; chown root:root /etc/at.allow; chmod 600 /etc/at.allow; grep -q '^root$' /etc/at.allow || echo root >> /etc/at.allow; rm -f /etc/at.deny
verify-cmd=[ -f /etc/at.allow ] && [ ! -f /etc/at.deny ]

[LOGG-001]
test-no=LOGG-2230
title=Ensure rsyslog is installed
section=6.1.2.1
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis test detects a running RSyslog daemon; CIS control is specifically about the package being installed (broader intent, same tool)
fix-cmd=apt-get install -y rsyslog >/dev/null 2>&1; systemctl enable --now rsyslog >/dev/null 2>&1
verify-cmd=pgrep -x rsyslogd >/dev/null 2>&1

[LOGG-002]
test-no=LOGG-2136
title=Ensure journald service is active
section=6.1.1.1.1
severity=Medium
category=security
level=L1
mapping=exact
fix-cmd=systemctl enable --now systemd-journald >/dev/null 2>&1
verify-cmd=pgrep -x systemd-journal >/dev/null 2>&1

[FIRE-001]
test-no=FIRE-4590
title=Ensure ufw service is configured
section=4.1.2
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis test detects whether any firewall solution is active (ufw, iptables, nftables, etc), CIS control is specifically about ufw

# Note: this v3.0.0 benchmark reclassifies "Ensure logrotate is configured"
# (6.1.2.8) as a Manual control (it was Automated in the 24.04/v2.0.0
# benchmark) - not mapped here since Lynis can't back an automated PASS/FAIL
# claim for a control the benchmark itself says requires manual review.
