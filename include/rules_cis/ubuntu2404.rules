#################################################################################
#
# CIS Benchmark mapping - Ubuntu 24.04 LTS - LEVEL 1
# Source: CIS_Ubuntu_Linux_24.04_LTS_Benchmark_v2.0.0.pdf (Level 1 controls only)
#
# Format: one [ID] block per rule, ini-style, values as key=value.
# Fields:
#   test-no   Lynis test ID this rule cross-references (see include/tests_*)
#   title     CIS control title (verbatim from benchmark where mapping=exact)
#   section   CIS Benchmark section number
#   severity  Low | Medium | High
#   category  Matches Lynis --category (security/basics/crypto/performance)
#   level     L1 | L2 - CIS profile level. This file is L1 only; see the
#             companion ubuntu2404-l2.rules for Level 2 controls.
#   mapping   exact    = Lynis test checks literally the same config item as
#                        the CIS control
#             approx   = Lynis test covers the same area/intent but isn't a
#                        1:1 check (broader or narrower scope) - review before
#                        treating a PASS/FAIL here as a compliance guarantee
#   note      Only present for mapping=approx, explains the gap
#
# Scope: only CIS Level 1 controls are mapped here. Remediation (Fase 3) is
# only planned for L1 - L2 hardens further but with higher risk of breaking
# things (e.g. separate partitions, ufw outgoing default), so L2 stays
# audit-only/informational unless a human decides otherwise. CIS "Manual"
# controls (require human judgment/procedure, no deterministic audit command)
# are intentionally not included in either file.
#
#################################################################################

[SSH-001]
test-no=SSH-7408
title=Ensure sshd PermitRootLogin is disabled
section=5.1.20
severity=High
category=security
level=L1
mapping=exact
backup-file=/etc/ssh/sshd_config
fix-cmd=grep -Eq '^[[:space:]]*PermitRootLogin' /etc/ssh/sshd_config && sed -i -E 's/^[[:space:]]*#?[[:space:]]*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config || echo 'PermitRootLogin no' >> /etc/ssh/sshd_config
verify-cmd=grep -Eq '^PermitRootLogin[[:space:]]+no' /etc/ssh/sshd_config
post-cmd=sshd -t 2>/dev/null && (systemctl reload sshd 2>/dev/null || systemctl reload ssh 2>/dev/null) || true

[SSH-002]
test-no=SSH-7440
title=Ensure sshd access is configured
section=5.1.4
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-001]
test-no=AUTH-9204
title=Ensure root is the only UID 0 account
section=5.4.2.1
severity=High
category=security
level=L1
mapping=exact

[AUTH-002]
test-no=AUTH-9208
title=Ensure no duplicate user names exist
section=7.2.7
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-003]
test-no=AUTH-9222
title=Ensure no duplicate GIDs exist
section=7.2.6
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-004]
test-no=AUTH-9226
title=Ensure no duplicate group names exist
section=7.2.8
severity=Medium
category=security
level=L1
mapping=exact

[AUTH-005]
test-no=AUTH-9328
title=Ensure default user umask is configured
section=5.4.3.3
severity=Low
category=security
level=L1
mapping=exact
backup-file=/etc/profile
fix-cmd=grep -Eq '^[[:space:]]*umask[[:space:]]+[0-9]+' /etc/profile && sed -i -E 's/^([[:space:]]*umask[[:space:]]+)[0-9]+/\1027/' /etc/profile || echo 'umask 027' >> /etc/profile
verify-cmd=grep -Eq '^[[:space:]]*umask[[:space:]]+(077|027|0077|0027)([^0-9]|$)' /etc/profile

[AUTH-006]
test-no=AUTH-9262
title=Ensure pam_pwquality module is enabled
section=5.3.2.3
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis checks presence of password strength testing tools in general (PAM), CIS control specifically requires the pam_pwquality module

[AUTH-007]
test-no=AUTH-9286
title=Ensure password expiration is configured
section=5.4.1.1
severity=Medium
category=security
level=L1
mapping=approx
note=Lynis checks general user password aging, CIS control specifies the exact PASS_MAX_DAYS threshold

[KRNL-001]
test-no=KRNL-5820
title=Ensure fs.suid_dumpable is configured
section=1.5.4
